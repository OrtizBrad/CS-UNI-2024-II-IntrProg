#include <iostream>
#include <algorithm>
#include <vector>
using namespace std;
int main(){
    int vector[] = {45, 78, 23, 56, 23, 67, 90, 13};
    int n = sizeof(vector)/sizeof(vector[0]);
    reverse(vector, vector + n);
    for(int i = 0; i < n; i++){
        cout << vector[i] << " ";
    }
    return 0;
}
